{
  "name": "desktop-cat",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "sprites": "node scripts/export-sprites-from-aseprite.mjs",
    "icons": "node scripts/generate-app-icons.mjs",
    "tauri": "tauri",
    "dev:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop-desktop-cat.ps1",
    "dev:fresh": "npm run dev:stop && npm run tauri dev",
    "package": "npm run tauri build && node scripts/copy-installer.mjs",
    "package:mac": "npm run tauri build -- --bundles dmg && node scripts/copy-installer.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-autostart": "^2.5.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "ase-parser": "^0.0.18",
    "sharp": "^0.34.5",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  }
}
